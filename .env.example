SPRING_PROFILES_ACTIVE=local
APP_PORT=8080
LOCAL_DEV_AUTH_ENABLED=true

DB_PORT=3306
DB_HOST=localhost
DB_DATABASE=koready
DB_USERNAME=koready
DB_PASSWORD=replace-with-local-mysql-password
DB_ROOT_PASSWORD=replace-with-local-mysql-root-password
DB_URL=jdbc:mysql://localhost:3306/koready?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Seoul
DB_POOL_SIZE=5
DB_MIN_IDLE=1
DB_SSL_MODE=require

KTO_SERVICE_KEY=replace-with-local-data-go-kr-service-key
KTO_MAX_RESPONSE_BYTES=4194304
KTO_CONNECT_TIMEOUT=3s
KTO_READ_TIMEOUT=10s
KTO_BATCH_PAGE_SIZE=200
KTO_BATCH_FLUSH_SIZE=50
KTO_BATCH_MAX_CONCURRENCY=1
KTO_SNAPSHOT_STORAGE=local
KTO_SNAPSHOT_DIRECTORY=replace-with-an-absolute-local-snapshot-directory
KTO_SNAPSHOT_S3_BUCKET=replace-with-private-s3-bucket-name
KTO_SNAPSHOT_S3_CONNECT_TIMEOUT=3s
KTO_SNAPSHOT_S3_READ_TIMEOUT=10s

# Kakao location search (staging/prod only; local uses deterministic fixtures)
LOCATION_SEARCH_PROVIDER=disabled
KAKAO_REST_API_KEY=replace-with-kakao-rest-api-key
KAKAO_LOCAL_BASE_URL=https://dapi.kakao.com
KAKAO_LOCAL_MAX_RESPONSE_BYTES=524288
KAKAO_LOCAL_CONNECT_TIMEOUT=3s
KAKAO_LOCAL_READ_TIMEOUT=5s
LOCATION_SEARCH_TOKEN_SECRET=replace-with-at-least-32-random-bytes
LOCATION_SEARCH_TOKEN_TTL=10m
AWS_REGION=ap-northeast-2
KAKAO_REST_API_KEY=replace-with-local-kakao-rest-api-key
TMAP_APP_KEY=replace-with-local-tmap-app-key
JWT_SECRET=replace-with-local-development-jwt-secret
